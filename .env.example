# ─── SMTP (Cyberfolks) ────────────────────────────────────────────────────────
# Host SMTP z panelu Cyberfolks (Poczta → Konfiguracja klienta)
SMTP_HOST=mail.cyberfolks.pl

# Port 465 = SSL/TLS (zalecany), 587 = STARTTLS
SMTP_PORT=465

# Skrzynka nadawcy — musi istnieć na Cyberfolks
SMTP_USER=formularz@ns-radcy.pl

# Hasło do skrzynki formularz@ns-radcy.pl
SMTP_PASS=haslo_skrzynki

# Odbiorca zapytań z formularza
SMTP_TO=sekretariat@ns-radcy.pl

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Domena(y) frontendu — tylko one mogą wysyłać żądania do /api/contact.
# Można podać kilka adresów po przecinku (np. z www i bez www).
ALLOWED_ORIGIN=https://ns-radcy.pl,https://www.ns-radcy.pl

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Dodawane automatycznie przez integrację Upstash w Vercel Marketplace.
# Do lokalnego dev: pobierz z https://console.upstash.com → baza → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ─── Jak ustawić zmienne ──────────────────────────────────────────────────────
# Produkcja (Vercel): projekt kns-green → Settings → Environment Variables
# Lokalny dev:        skopiuj ten plik jako keystatic-app/.env.local i uzupełnij
#                     (plik .env.local nie jest commitowany)
